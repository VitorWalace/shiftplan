# --- Frontend (Vite, bundled into the client — never put secrets here) ---
# Project Settings > API > Project URL (NOT the dashboard link)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Project Settings > API > Project API keys > anon public
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Backend (Vercel serverless functions under /api — server-only, NEVER prefix with VITE_) ---
# Same project URL as above, without the VITE_ prefix
SUPABASE_URL=https://your-project-ref.supabase.co
# Project Settings > API > Project API keys > service_role (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Asaas dashboard > Integrations > API Key (use the sandbox key for testing)
ASAAS_API_KEY=your-asaas-api-key
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
# Token you choose and also paste into Asaas dashboard > Integrations > Webhooks
ASAAS_WEBHOOK_TOKEN=choose-a-random-secret-token
